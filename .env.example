# =============================================================
# AMIRA GOLD LUXURY — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================

# --- App ---
APP_NAME=GoldVault
APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-to-random-64-char-string

# --- Database ---
POSTGRES_USER=gold_user
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=gold_db
DATABASE_URL=postgresql+asyncpg://gold_user:change-me-strong-db-password@db:5432/gold_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Telegram Bot ---
# Get from @BotFather
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi

# Webhook mode (recommended for production — leave empty for polling)
WEBHOOK_HOST=
WEBHOOK_PATH=/bot/webhook
WEBHOOK_SECRET=

# --- Gold Price API ---
# Primary: https://www.goldapi.io (free tier available)
# Fallback: Swissquote public feed used automatically when GoldAPI fails (no key needed)
GOLD_API_KEY=goldapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-io

# --- Exchange Rate API (AED to USD conversion) ---
# Sign up FREE at https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Crypto Payments ---
# Sign up at https://nowpayments.io
NOWPAYMENTS_API_KEY=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
NOWPAYMENTS_IPN_SECRET=your-ipn-secret-key
# Must be public HTTPS: https://yourdomain.com/api/v1/webhooks/nowpayments
NOWPAYMENTS_CALLBACK_URL=https://yourdomain.com/api/v1/webhooks/nowpayments

# --- Business Logic ---
MARKUP_PERCENT=2.5
SPREAD_PERCENT=1.5
PRICE_CACHE_TTL=60
PRICE_LOCK_DURATION=300
REFERRAL_BONUS_PERCENT=1.0
MIN_BUY_GRAMS=0.1
MAX_BUY_GRAMS=10000.0
MIN_SELL_GRAMS=0.1

# --- Admin Panel ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-to-random-64-char-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# --- Admin Telegram IDs ---
# Comma-separated Telegram user IDs for admin alerts
# Get your ID from @userinfobot
ADMIN_TELEGRAM_IDS=123456789

# --- Supported Cryptos ---
SUPPORTED_CRYPTOS=BTC,ETH,USDT

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30
