# =============================================================
# GoldVault — .gitignore
# =============================================================

# --- Secrets (NEVER commit) ---
.env
*.env
.env.local
.env.*.local
secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.egg

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.python-version

# --- Testing ---
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
*.cover

# --- Type checking ---
.mypy_cache/
.dmypy.json
.pyright/

# --- Linting ---
.ruff_cache/

# --- IDEs ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Docker ---
docker-compose.override.yml

# --- Alembic ---
migrations/versions/*.pyc

# --- Logs ---
*.log
logs/

# --- Celery ---
celerybeat-schedule
celerybeat.pid
celery-data/

# --- Claude Code ---
.claude/

# --- Misc ---
*.bak
*.tmp
*.orig
.cache/
